{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goalos.dev/schemas/intent-graph.schema.json",
  "title": "IntentGraph",
  "description": "A complete intent graph containing all goals and their relationships",
  "type": "object",
  "required": ["id", "version", "owner", "goals", "createdAt", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the intent graph",
      "pattern": "^graph_[a-zA-Z0-9_-]+$"
    },
    "version": {
      "type": "string",
      "description": "GoalOS specification version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "owner": {
      "type": "string",
      "description": "Identifier of the graph owner (user ID or email)",
      "minLength": 1,
      "maxLength": 255
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for the intent graph",
      "maxLength": 500
    },
    "description": {
      "type": "string",
      "description": "Description of the intent graph and its purpose",
      "maxLength": 2000
    },
    "goals": {
      "type": "array",
      "description": "All goals in the graph",
      "items": {
        "$ref": "https://goalos.dev/schemas/goal.schema.json"
      },
      "minItems": 0
    },
    "defaultPermissions": {
      "type": "array",
      "description": "Default permissions applied to all goals",
      "items": {
        "$ref": "https://goalos.dev/schemas/permission.schema.json"
      },
      "minItems": 0
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when the graph was created",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of the last update to the graph",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "description": "Additional custom metadata for extensibility",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "definitions": {
    "goalIdRef": {
      "type": "string",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    }
  }
}
