{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goalos.dev/schemas/goal.schema.json",
  "title": "Goal",
  "description": "A single goal in the GoalOS intent graph",
  "type": "object",
  "required": ["id", "title", "status", "priority", "createdAt", "updatedAt", "version"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the goal (nanoid format)",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "description": "Short, descriptive title of the goal",
      "minLength": 1,
      "maxLength": 500
    },
    "description": {
      "type": "string",
      "description": "Longer explanation of the goal and its context",
      "maxLength": 5000
    },
    "parentId": {
      "type": ["string", "null"],
      "description": "ID of the parent goal (hierarchical relationship)",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    },
    "status": {
      "type": "string",
      "description": "Current status of the goal",
      "enum": ["active", "planned", "blocked", "paused", "completed", "abandoned"]
    },
    "priority": {
      "type": "object",
      "description": "Priority information for the goal",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "description": "Priority level",
          "enum": ["critical", "high", "medium", "low", "someday"]
        },
        "score": {
          "type": "integer",
          "description": "Numeric priority score for sorting (0-100)",
          "minimum": 0,
          "maximum": 100
        },
        "reason": {
          "type": "string",
          "description": "Explanation for the priority level",
          "maxLength": 1000
        }
      },
      "additionalProperties": false
    },
    "successCriteria": {
      "type": "array",
      "description": "Measurable criteria that define when the goal is complete",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "minItems": 0,
      "maxItems": 20
    },
    "deadline": {
      "type": "string",
      "description": "ISO 8601 deadline for completing the goal",
      "format": "date-time"
    },
    "timeHorizon": {
      "type": "string",
      "description": "Expected timeframe for completing the goal",
      "enum": ["today", "this_week", "this_month", "this_quarter", "this_year", "long_term"]
    },
    "estimatedEffort": {
      "type": "object",
      "description": "Estimated effort required to complete the goal",
      "required": ["value", "unit"],
      "properties": {
        "value": {
          "type": "number",
          "description": "Numeric value of the effort",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "description": "Unit of time measurement",
          "enum": ["minutes", "hours", "days", "weeks"]
        }
      },
      "additionalProperties": false
    },
    "motivation": {
      "type": "string",
      "description": "Why this goal matters and its significance",
      "maxLength": 2000
    },
    "tags": {
      "type": "array",
      "description": "Tags for organizing and categorizing goals",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "minItems": 0,
      "maxItems": 50
    },
    "domain": {
      "type": "string",
      "description": "Domain or category of the goal (e.g., work, personal, health, creative)",
      "minLength": 1,
      "maxLength": 100
    },
    "dependencies": {
      "type": "array",
      "description": "Other goals this goal depends on or relates to",
      "items": {
        "$ref": "https://goalos.dev/schemas/dependency.schema.json"
      },
      "minItems": 0,
      "maxItems": 50
    },
    "permissions": {
      "type": "array",
      "description": "Permissions granted to specific agents for this goal",
      "items": {
        "$ref": "https://goalos.dev/schemas/permission.schema.json"
      },
      "minItems": 0
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when the goal was created",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of the last update to the goal",
      "format": "date-time"
    },
    "completedAt": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when the goal was completed",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string",
      "description": "Identifier of the agent or user that created this goal",
      "maxLength": 255
    },
    "version": {
      "type": "integer",
      "description": "Version number for tracking changes to the goal",
      "minimum": 1
    },
    "metadata": {
      "type": "object",
      "description": "Additional custom metadata for extensibility",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
