{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goalos.dev/schemas/dependency.schema.json",
  "title": "Dependency",
  "description": "A dependency relationship between two goals",
  "type": "object",
  "required": ["type", "targetGoalId"],
  "properties": {
    "type": {
      "type": "string",
      "description": "Type of dependency relationship",
      "enum": ["blocks", "requires", "enables", "related"]
    },
    "targetGoalId": {
      "type": "string",
      "description": "ID of the goal that this dependency points to",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    },
    "description": {
      "type": "string",
      "description": "Human-readable explanation of the dependency",
      "maxLength": 1000
    }
  },
  "additionalProperties": false
}
