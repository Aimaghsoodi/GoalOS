{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://goalos.dev/schemas/event.schema.json",
  "title": "GoalEvent",
  "description": "An event representing a change to a goal",
  "type": "object",
  "required": ["id", "type", "goalId", "timestamp"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the event (nanoid format)",
      "pattern": "^event_[a-zA-Z0-9_-]+$"
    },
    "type": {
      "type": "string",
      "description": "Type of event that occurred",
      "enum": [
        "goal.created",
        "goal.updated",
        "goal.completed",
        "goal.abandoned",
        "goal.blocked",
        "goal.unblocked",
        "goal.prioritized",
        "goal.dependency_added",
        "goal.dependency_removed",
        "goal.permission_granted",
        "goal.permission_revoked"
      ]
    },
    "goalId": {
      "type": "string",
      "description": "ID of the goal that changed",
      "pattern": "^goal_[a-zA-Z0-9_-]+$"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp when the event occurred",
      "format": "date-time"
    },
    "agentId": {
      "type": "string",
      "description": "Identifier of the agent or user that triggered the event",
      "maxLength": 255
    },
    "data": {
      "type": "object",
      "description": "Event-specific data payload",
      "additionalProperties": true
    },
    "previousState": {
      "type": "object",
      "description": "Partial state of the goal before the change (for tracking what changed)",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
