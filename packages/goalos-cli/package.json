{
  "name": "goalos",
  "version": "0.1.0",
  "description": "GoalOS CLI — manage your personal AI intent graph",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "goalos": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Aimaghsoodi/GoalOS.git"
  },
  "homepage": "https://github.com/Aimaghsoodi/GoalOS#readme",
  "bugs": {
    "url": "https://github.com/Aimaghsoodi/GoalOS/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format \"cjs,esm\" --dts --sourcemap",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "goals",
    "intent",
    "cli",
    "goalos"
  ],
  "license": "MIT",
  "dependencies": {
    "@goalos/core": "workspace:*",
    "@goalos/mcp-server": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.0",
    "boxen": "^7.0.0",
    "inquirer": "^9.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.50.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
