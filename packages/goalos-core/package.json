{
  "name": "@goalos/core",
  "version": "0.1.0",
  "description": "GoalOS core library — structured intent graphs for AI agent alignment",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Aimaghsoodi/GoalOS.git"
  },
  "homepage": "https://github.com/Aimaghsoodi/GoalOS#readme",
  "bugs": {
    "url": "https://github.com/Aimaghsoodi/GoalOS/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format \"cjs,esm\" --dts --sourcemap",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "goals",
    "intent",
    "mcp",
    "llm",
    "alignment"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.50.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
